# Python cache
__pycache__/
*.py[cod]
*$py.class

# Virtual environment
.venv/
venv/
env/

# Environment variables
.env
.env.*
!.env.example
!.env.test.example

# IDE / Editor
.vscode/
.idea/

# Claude Code workspace settings (各自ローカル)
.claude/

# OS files
.DS_Store

# Test / coverage
.pytest_cache/
.coverage
htmlcov/

# Build / package
build/
dist/
*.egg-info/

# Next.js build output (compiled bundles embed the public anon key)
.next/
frontend/.next/
out/
frontend/out/
node_modules/
frontend/node_modules/

# Logs
*.log

# Local doc backups (e.g. docs/architecture.bakup.20260506.md)
docs/*.bakup.*.md
