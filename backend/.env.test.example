# 結合テスト (`pytest -m integration`) 用の環境変数テンプレート。
# 実際の値を入れたファイルは `.env.test` として保存 (gitignore 済み)。
#
# テスト専用の Supabase プロジェクトの値を使うこと。本番プロジェクトを指定すると
# テストでユーザー作成/削除を繰り返してデータが汚染されるので絶対に避ける。

TEST_SUPABASE_URL=https://your-test-project.supabase.co
TEST_SUPABASE_ANON_KEY=your-anon-public-key
TEST_SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
