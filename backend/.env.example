SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
# Optional but recommended: Project Settings -> API -> JWT Secret.
# When set, FastAPI verifies user JWTs locally instead of calling Supabase Auth per request.
SUPABASE_JWT_SECRET=your_jwt_secret_here

# CORS allowed origins (comma-separated). Defaults to http://localhost:3000 if unset.
# Production: set to your frontend URL(s), e.g. https://app.example.com,https://staging.example.com
ALLOWED_ORIGINS=http://localhost:3000
